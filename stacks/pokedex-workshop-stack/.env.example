# Shared across modules. Copy to .env and adjust.
# DB_TYPE=mongo | postgres (used by API and root compose)
DB_TYPE=mongo

# API
PORT=3002
NODE_ENV=development
JWT_SECRET=change-me-in-production-min-32-chars

# Database (API connects to service name "database" in compose)
DB_HOST=database

# MongoDB
MONGO_PORT=27017
MONGO_INITDB_DATABASE=pokedex

# PostgreSQL
PG_PORT=5432
PG_USER=pokedex
PG_PASSWORD=pokedex_secret
PG_DATABASE=pokedex

# Frontend (build-time for Vite). On a VPS, set to your API URL (e.g. http://YOUR_IP:3002).
VITE_API_URL=http://localhost:3002

# API CORS: allow this frontend origin when deployed (e.g. http://YOUR_IP:3000). Comma-separated for multiple.
# Leave empty for local dev (allows all).
CORS_ORIGIN=
